# ============================================================================
# ConverSight Automation — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored, so secrets stay on your machine.
# After editing, RESTART `npm run dev` — Next.js does NOT hot-reload env vars.
# ============================================================================

# Session signing secret used by lib/auth.ts to sign the cs_session JWT cookie.
# Any long random string. Generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ----------------------------------------------------------------------------
# Universe Engine (IrtAutomationFlow step flow) connection
# When ANY of these three are missing, executeAutomation() returns a
# simulated result without touching the real engine — and the request
# is parked in "Waiting for Approval" with a clear warning.
# ----------------------------------------------------------------------------

# Base URL of the Universe Engine API. Do NOT include a trailing slash.
# Example: https://api.conversight.ai/universe-engine/v2/api
UE_BASE_URL=https://api.conversight.ai/universe-engine/v2/api

# The CRN of the step flow that IrtAutomationFlow is registered as.
# This is the same CRN you used in the curl example you shared.
UE_STEP_FLOW_CRN=crn:prod:us:step_flow:9b505609-832c-453b-9e07-19897c59273e:standard:irtautomation

# Bearer token for the engine. Include the "JWT " prefix exactly as shown.
# Example: JWT eyJhbGciOiJIUzI1NiJ9...
UE_BEARER_TOKEN=JWT <paste-your-token-here>

# (optional) Path template used to construct the execute URL.
# Default: /execute/step_flow/{crn}  →  ${UE_BASE_URL}/execute/step_flow/<crn>
# {crn} is substituted at runtime.
# If your engine uses a different path (you'll get 404 otherwise), set it here.
# Examples to try if 404:
#   UE_EXECUTE_PATH=/step_flow/{crn}/execute
#   UE_EXECUTE_PATH=/v2/api/invoke/{crn}
#   UE_EXECUTE_PATH=/resource/{crn}/execute
# UE_EXECUTE_PATH=/execute/step_flow/{crn}

# (optional) Full URL override — if set, UE_BASE_URL and UE_EXECUTE_PATH are
# both ignored and this exact URL is POSTed to. Use only when the URL doesn't
# fit the {base}+{path} pattern (e.g. has its own query string).
# UE_EXECUTE_URL=https://api.conversight.ai/some/full/path

# ----------------------------------------------------------------------------
# Asana integration (CS-IRT-Automation project)
# When ANY of these are missing, Asana calls are silently skipped.
# ----------------------------------------------------------------------------

# Personal Access Token — generate at https://app.asana.com/0/my-apps
ASANA_TOKEN=2/xxxx/yyyy:zzzz

# Project GID — from URL: app.asana.com/0/<PROJECT_GID>/list
ASANA_PROJECT_GID=1215194143042801

# Section GIDs — run: curl -H "Authorization: Bearer $ASANA_TOKEN" \
#   "https://app.asana.com/api/1.0/projects/$ASANA_PROJECT_GID/sections"
ASANA_SECTION_TODO=1215194143042804
ASANA_SECTION_INPROGRESS=1215194143042805
ASANA_SECTION_DONE=1215194143042806
ASANA_SECTION_REJECTED=1215194143042807
