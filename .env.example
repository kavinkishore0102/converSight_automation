# Session signing secret for JWT cookies (lib/auth.ts)
SESSION_SECRET=change-me-to-a-long-random-string

# IrtAutomationFlow / Universe Engine connection (lib/automation-engine.ts)
# When these are not set, "Run automation" returns a simulated result so the
# request/approval flow can be tested end-to-end without a live backend.
UE_BASE_URL=https://api.conversight.ai/universe-engine/v2/api
UE_STEP_FLOW_CRN=crn:prod:us:step_flow:9b505609-832c-453b-9e07-19897c59273e:standard:irtautomation
UE_BEARER_TOKEN=JWT <token>
