TOKEN='Bearer JWT eyJhbGciOiJIUzI1NiJ9..wXILIUVFmTUOi1jWMhx3rmW_8Gv-J77Ej5zCTuMz1ys'
BASE='https://api.conversight.ai/universe-engine/v2/api'
CRN='crn:dev:us:step_flow:9b505609-832c-453b-9e07-19897c59273e:standard:irtautomation'
BODY='{"config":{"source":"portal","category":"Activate Dataset","details":"{}","slackID":""}}'

for PATH in \
  "/execute/step_flow/$CRN" \
  "/step_flow/$CRN/execute" \
  "/resource/$CRN/execute" \
  "/resource/$CRN/invoke" \
  "/resource/$CRN/run" \
  "/invoke/$CRN" \
  "/execution/$CRN" \
  "/executions" \
  "/step_flow/execute" \
  "/run/$CRN" \
  "/v2/api/run/$CRN"
do
  STATUS=$(curl -s -o /dev/null -w "%{http_code}" -X POST "$BASE$PATH" \
    -H "Content-Type: application/json" \
    -H "Authorization: $TOKEN" \
    -d "$BODY")
  echo "$STATUS  POST $BASE$PATH"
done